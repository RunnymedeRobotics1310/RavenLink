bridge:
  team: 1310
  obs_host: localhost
  obs_port: 4455
  obs_password: ""
  stop_delay: 10
  poll_interval: 0.05
  log_level: INFO
  record_trigger: fms
  collect_trigger: fms
  auto_teleop_gap: 5
  nt_disconnect_grace: 15
  launch_on_login: true

telemetry:
  nt_paths:
    # /FMSInfo/ is always subscribed regardless of this list — required for
    # match detection. /.schema/ is needed for struct types (Pose2d, etc.)
    # to render correctly in AdvantageScope.
    - /FMSInfo/
    - /.schema/
    - /SmartDashboard/
    - /Shuffleboard/
  data_dir: ./data
  retention_days: 30

ravenbrain:
  url: ""
  # Auth mode: two ways to authenticate with the server.
  #
  #  1. Legacy (RavenBrain): set username + password. RavenLink calls
  #     POST /login to exchange them for a short-lived JWT.
  #  2. API key (RavenScope): set api_key to an rsk_live_… token. RavenLink
  #     skips /login entirely and sends Authorization: Bearer <api_key>
  #     on every request.
  #
  # If api_key is non-empty it wins — username/password are ignored.
  username: telemetry-agent
  password: ""
  api_key: ""
  batch_size: 50
  upload_interval: 10

dashboard:
  enabled: true
  port: 8080
